{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS", "label": "Prometheus", "description": "Grafana Cloud Prometheus",
      "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": ""       }
  ],
  "description": "EQ2 Companion — per-DB size growth, row counts, and server-error rates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["eq2companion", "databases"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EQ2 Companion — Databases",
  "uid": "eq2companion-databases",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false, "multi": false, "name": "datasource",
        "options": [], "query": "prometheus", "refresh": 1, "type": "datasource", "label": "Data source"
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "On-disk size", "type": "row" },

    {
      "id": 1, "type": "timeseries", "title": "Database file size (by DB)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Bytes on disk for each SQLite file. Steep growth = ingest activity (parses) or content additions (raids). Flat = idle. Missing series = file absent on the volume.",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "none" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max", "delta"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "db_file_size_bytes{job=\"eq2companion\"}", "legendFormat": "{{db}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }, "id": 101, "title": "Row counts", "type": "row" },

    {
      "id": 10, "type": "timeseries", "title": "users.db — by access status",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Approved vs pending vs denied. Watch pending — non-zero means there's a review backlog.",
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "denied" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "pending" },  "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "approved" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "users_total{job=\"eq2companion\"}", "legendFormat": "{{status}}", "refId": "A" }]
    },

    {
      "id": 11, "type": "timeseries", "title": "users.db — character claims by status",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Approved (linked) / pending (queue) / rejected / withdrawn / superseded character claims.",
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "character_claims_total{job=\"eq2companion\"}", "legendFormat": "{{status}}", "refId": "A" }]
    },

    {
      "id": 12, "type": "timeseries", "title": "parses.db — encounters (visible vs hidden)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Visible = live leaderboard rows. Hidden = soft-deleted (rare; admin action).",
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "parses_encounters_total{job=\"eq2companion\"}", "legendFormat": "{{visibility}}", "refId": "A" }]
    },

    {
      "id": 13, "type": "stat", "title": "Raid encounters curated",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Boss strategies in raids.db.",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "raid_encounters_total{job=\"eq2companion\"}", "legendFormat": "encounters", "refId": "A" }]
    },

    {
      "id": 14, "type": "stat", "title": "ACT triggers",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "act_triggers_total{job=\"eq2companion\"}", "legendFormat": "triggers", "refId": "A" }]
    },

    {
      "id": 15, "type": "stat", "title": "ACT spell timers",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "act_spell_timers_total{job=\"eq2companion\"}", "legendFormat": "spell timers", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "id": 102, "title": "Errors", "type": "row" },

    {
      "id": 20, "type": "timeseries", "title": "Server errors / sec (by route, 5 m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "5xx-class responses only — 4xx (auth/validation) deliberately excluded so this surfaces server-side problems, not user errors.",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(source) (rate(app_errors_total{job=\"eq2companion\"}[5m]))", "legendFormat": "{{source}}", "refId": "A" }]
    },

    {
      "id": 21, "type": "timeseries", "title": "5xx rate as % of total (5 m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Server-error rate over the full request volume. Healthy = ~0. Spike = look at the per-route panel on the left.",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 3, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(http_requests_total{job=\"eq2companion\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"eq2companion\"}[5m])), 0.001)",
        "legendFormat": "5xx rate", "refId": "A" }]
    }

  ]
}
