{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS", "label": "Prometheus", "description": "Grafana Cloud Prometheus",
      "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": ""       }
  ],
  "description": "EQ2 Companion — Daybreak Census API health, throughput, errors, and the in-process cache hit ratio.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["eq2companion", "census"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EQ2 Companion — Census",
  "uid": "eq2companion-census",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false, "multi": false, "name": "datasource",
        "options": [], "query": "prometheus", "refresh": 1, "type": "datasource", "label": "Data source"
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Liveness", "type": "row" },

    {
      "id": 1, "type": "stat", "title": "Census liveness",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "1 = up, 0 = down/unknown. Driven by the background poll that hits /eq2/world?c:limit=1 every 5 m AND validates the response body (no errorCode, returned >= 0).",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ] }
        }, "overrides": []
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "census_health_status{job=\"eq2companion\"}", "legendFormat": "Census", "refId": "A" }]
    },

    {
      "id": 2, "type": "timeseries", "title": "Liveness over time",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Step function — every flip from 1 → 0 is a Census outage event.",
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0, "min": 0, "max": 1,
          "custom": { "lineWidth": 3, "fillOpacity": 25, "showPoints": "never", "drawStyle": "line", "lineInterpolation": "stepAfter" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.5 }] }
        }, "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "census_health_status{job=\"eq2companion\"}", "legendFormat": "up", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }, "id": 101, "title": "Throughput", "type": "row" },

    {
      "id": 10, "type": "timeseries", "title": "Census requests / sec (by endpoint + status)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Stacked by Census collection (character/guild/item) and outcome. Red bands = errors getting through to the API.",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*error.*" },  "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*success.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(endpoint, status) (rate(census_api_requests_total{job=\"eq2companion\"}[5m]))",
        "legendFormat": "{{endpoint}} · {{status}}", "refId": "A" }]
    },

    {
      "id": 11, "type": "timeseries", "title": "Census p95 latency by endpoint",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Round-trip time to Daybreak's Census API. Spikes here can flag upstream issues before liveness flips.",
      "fieldConfig": {
        "defaults": { "unit": "s", "decimals": 2, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" } }, "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum by(le, endpoint) (rate(census_api_duration_seconds_bucket{job=\"eq2companion\"}[5m])))",
        "legendFormat": "{{endpoint}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 102, "title": "Cache", "type": "row" },

    {
      "id": 20, "type": "timeseries", "title": "Cache hit ratio (5 m, per cache)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "hits / (hits + misses + stale). Anything below ~80 % during normal use means the cache TTL or warming is off.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1, "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }
          ] }
        }, "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(cache) (rate(cache_hits_total{job=\"eq2companion\"}[5m])) / clamp_min(sum by(cache) (rate(cache_hits_total{job=\"eq2companion\"}[5m]) + rate(cache_misses_total{job=\"eq2companion\"}[5m]) + rate(cache_stale_total{job=\"eq2companion\"}[5m])), 0.001)",
        "legendFormat": "{{cache}}", "refId": "A" }]
    },

    {
      "id": 21, "type": "timeseries", "title": "Cache events / sec (hits · misses · stale)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Per-cache event mix. 'stale' = served from cache + fired a background refresh.",
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 1, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*miss.*" },  "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*stale.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow","mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*hit.*" },   "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(cache) (rate(cache_hits_total{job=\"eq2companion\"}[5m]))",   "legendFormat": "{{cache}} hit",   "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(cache) (rate(cache_misses_total{job=\"eq2companion\"}[5m]))", "legendFormat": "{{cache}} miss",  "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(cache) (rate(cache_stale_total{job=\"eq2companion\"}[5m]))",  "legendFormat": "{{cache}} stale", "refId": "C" }
      ]
    },

    {
      "id": 22, "type": "timeseries", "title": "Cache live size (entries)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Snapshot count of entries in each TTLCache. Growth without bound = TTL not evicting. Sudden drop = explicit invalidate.",
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" } }, "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "cache_size{job=\"eq2companion\"}", "legendFormat": "{{cache}}", "refId": "A" }]
    }

  ]
}
