# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Uncommented lines are required (or have
# safe defaults for local dev). Commented-out lines are optional overrides.

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: display name/ID of the bot owner for the /fun cog ownership check.
# Find your ID: Discord → Settings → Advanced → Developer Mode, right-click yourself → Copy User ID
# OWNER_DISCORD_ID=your_discord_user_id_here

# Discord guild IDs that receive instant slash-command syncs (comma-separated).
# Commands also sync globally, but guild syncs propagate immediately for testing.
# DISCORD_SYNC_GUILD_IDS=your_guild_id_1,your_guild_id_2

# ── Census API ────────────────────────────────────────────────────────────────
# Get a service ID from https://census.daybreakgames.com/
# Using "example" works but is heavily rate-limited.
CENSUS_SERVICE_ID=your_service_id_here

# EverQuest 2 world/server name for guild and character lookups.
EQ2_WORLD=Varsoon

# EQ2 servers that the /api/parses/ingest endpoint accepts uploads from.
# Comma-separated, case-insensitive at comparison time. The ACT plugin
# (v0.1.14+) also reads this list from /api/auth/whoami and renders it
# in its settings UI. Defaults to the two active English-language EQ2
# TLE servers as of 2026 ("Varsoon,Wuoshi") so a fresh deploy works
# without manual config; override here when a new server launches.
ALLOWED_SERVERS=Varsoon,Wuoshi

# Max character level on this server (used to filter item results and AA checks).
# Set to the current TLE expansion's max level (e.g. 50, 70, 80, 100...).
SERVER_MAX_LEVEL=50

# Current expansion — full name (e.g. "Echoes of Faydwer"). Shown on the AA
# config endpoint, and used as the default Expansion on the rankings page
# (matched against zones.db expansion names; falls back to the most recent
# expansion that has raids if unset/unknown).
# SERVER_CURRENT_XPAC=Echoes of Faydwer

# ── Website / Discord OAuth ───────────────────────────────────────────────────
# Create an OAuth2 application at https://discord.com/developers/applications
# Add http://localhost:8000/api/auth/callback (dev) and your Railway URL (prod)
# as Redirect URIs under OAuth2 → General.
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Generate a strong random string for signing session cookies.
# python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Public URL of the site — used for og:image absolute URLs in social unfurls.
# Set this in Railway env vars to your deployed domain.
# VITE_APP_URL=https://your-railway-url.up.railway.app

# CORS origins allowed by the API server (comma-separated).
# In production set this to your actual frontend domain.
# CORS_ORIGINS=https://your-railway-url.up.railway.app

# ── Character Claiming ────────────────────────────────────────────────────────
# Comma-separated Discord user IDs with admin access (can approve/reject claims).
ADMIN_DISCORD_IDS=your_discord_id_here

# ── Server Launch Countdown ───────────────────────────────────────────────────
# ISO-8601 UTC datetime shown as a countdown widget on the site and via /when.
# Set to an empty string or a past date to suppress the widget entirely.
LAUNCH_DT=2026-06-09T20:00:00Z

# ── Security ──────────────────────────────────────────────────────────────────
# Set to false only for local HTTP development (disables the Secure cookie flag).
HTTPS_ONLY=true

# Set to true to expose /api/docs and /api/openapi.json (off by default).
# SHOW_API_DOCS=false

# ── Observability ─────────────────────────────────────────────────────────────
# Bearer token required to access the /metrics endpoint.
# If unset, the endpoint is open — always set this in production.
# python -c "import secrets; print(secrets.token_hex(32))"
# METRICS_TOKEN=your_metrics_token_here

# ── Database Paths ────────────────────────────────────────────────────────────
# Every DB has a DB_<name>_PATH override. Defaults sit under data/ alongside
# the application; in Railway, point each one at the persistent volume mount.
# The DB_ prefix keeps them grouped alphabetically in your env-var list.
#
#   DB_USERS_PATH       Discord logins, claims, api_tokens, roles, notifications.
#                       Backed up via litestream → R2.
#   DB_PARSES_PATH      Normalised ACT parse uploads (the rankings + DPS boards).
#                       Backed up via litestream → R2.
#   DB_CENSUS_PATH      Persistent best-known cache of Census character/guild
#                       lookups (web read path never blocks on the Census API).
#                       Lives on the volume so it survives redeploys.
#   DB_ITEMS_PATH       Census item cache (item tooltips, stats, set bonuses).
#                       Local-generated via scripts/download_items.py.
#   DB_SPELLS_PATH      Census spell cache (icons, tiers, given_by). Local-only.
#   DB_RECIPES_PATH     ~70k crafting recipes. Local-generated via download_recipes.
#   DB_CLASSES_PATH     Class catalogue (archetypes, parent classes). Built locally.
#   DB_ZONES_PATH       Zone + raid-boss roster reference. Built locally from
#                       scripts/dev/eq2_raid_bosses.review.txt — manual upload.
#   DB_RAIDS_PATH       Raid strategies + ACT trigger packs (human-edited content).
#                       Manual upload — accumulates edits, do not clobber.
#   DB_ACT_EXPORT_PATH  Path to ACT's OWN export.db that parses/act_reader.py reads
#                       from at ingest time (dev-only; not used in production).
#
# DB_USERS_PATH=/data/users.db
# DB_PARSES_PATH=/data/parses/parses.db
# DB_CENSUS_PATH=/data/census/census.db
# DB_ITEMS_PATH=/data/items/items.db
# DB_SPELLS_PATH=/data/spells/spells.db
# DB_RECIPES_PATH=/data/recipes/recipes.db
# DB_CLASSES_PATH=/data/classes/classes.db
# DB_ZONES_PATH=/data/zones/zones.db
# DB_RAIDS_PATH=/data/raids/raids.db
# DB_ACT_EXPORT_PATH=/data/parses/act_export.db
