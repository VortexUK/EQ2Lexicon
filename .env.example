# Copy this to .env and fill in your values
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: get a service ID from https://census.daybreakgames.com/
# Using "example" works but is rate-limited
CENSUS_SERVICE_ID=your_service_id_here
# EverQuest 2 world/server name for guild lookups
EQ2_WORLD=Varsoon
# Optional: cap item lookups by name to items usable at or below this level.
# Set to the current TLE expansion's max level (e.g. 70 for Echoes of Faydwer).
# If unset, no level filtering is applied.
# SERVER_MAX_LEVEL=70

# Website / Discord OAuth
# Create an application at https://discord.com/developers/applications
# Add http://localhost:8000/api/auth/callback (dev) and your Railway URL (prod) as redirect URIs
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback
# Generate a strong random string for signing session cookies, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-secret

# Public URL of the site — used for og:image absolute URL in social unfurls
# Set this in Railway env vars (e.g. https://eq2lexicon.up.railway.app)
# VITE_APP_URL=https://your-railway-url.up.railway.app

# Security flags (production defaults shown)
# Set HTTPS_ONLY=false only for local HTTP development (disables Secure cookie flag)
HTTPS_ONLY=true
# Set SHOW_API_DOCS=true to expose /api/docs and /api/openapi.json (off by default)
# SHOW_API_DOCS=false

# Character claiming
# Comma-separated Discord user IDs who can approve/reject character claims
# Find your ID: Discord → Settings → Advanced → Developer Mode on, then right-click yourself → Copy User ID
ADMIN_DISCORD_IDS=your_discord_id_here
# Optional: path for the users/claims SQLite DB (defaults to data/users.db)
# USERS_DB_PATH=/path/to/users.db
